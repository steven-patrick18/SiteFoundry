---
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import ProductCard from '../../components/ProductCard.astro';
import TrustFooter from '../../components/TrustFooter.astro';
import { params, site, href } from '../../lib/config.js';
import { catalogCategories } from '../../lib/catalog.js';

// One static page per category (each distinct thing visitors have searched).
// Only for shopping sites — other templates (e.g. retailers) skip these.
export function getStaticPaths() {
  if ((site.category ?? 'ecom_showcase') !== 'ecom_showcase') return [];
  return catalogCategories.map((category) => ({
    params: { slug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const brand = params.brand ?? {};
const count = category.products.length;

const title = `${category.title} — Compare Prices Across US Stores | ${brand.business_name}`;
const description = `Compare live prices on ${category.title} from ${count} top picks across major US retailers. Ratings, deals, and where to buy — updated on ${brand.business_name}.`;

const jsonLd = {
  '@context': 'https://schema.org/',
  '@type': 'ItemList',
  name: category.title,
  numberOfItems: count,
  itemListElement: category.products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://${site.domain}${href(`/product/${p.slug}/`)}`,
    name: p.title,
  })),
};
---
<Base title={title} description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <SiteHeader />

  <main class="wrap cat-head">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={href('/')}>Home</a>
      <span class="sep">›</span>
      <span>{category.title}</span>
    </nav>
    <h1>{category.title}</h1>
    <p class="cat-intro">
      Comparing {count} of the best {category.title} across major US stores — with
      live prices, ratings, and delivery estimates. Tap any product to see full
      details and head to the store.
    </p>
    <div class="ggrid">
      {category.products.map((p) => <ProductCard product={p} />)}
    </div>
  </main>

  <TrustFooter />
</Base>
