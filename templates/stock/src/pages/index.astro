---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ClaimsBar from '../components/ClaimsBar.astro';
import ShopControls from '../components/ShopControls.astro';
import ShopGrid from '../components/ShopGrid.astro';
import ProductCard from '../components/ProductCard.astro';
import ProductsGrid from '../components/ProductsGrid.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import LeadForm from '../components/LeadForm.astro';
import TrustFooter from '../components/TrustFooter.astro';
import { params, site, href } from '../lib/config.js';
import { catalogCategories, hasCatalog } from '../lib/catalog.js';
import { marked } from 'marked';

const category = site.category ?? 'ecom_showcase';
const disclosure = (params.legal?.affiliate_disclosure_md ?? '').trim();
// Prelander/comparison show the disclosure prominently near the top (§8).
const showTopDisclosure = disclosure && ['prelander', 'comparison'].includes(category);
const products = Array.isArray(params.products) ? params.products : [];
// catalog pages render as a shopping-results experience (search + chips + grid)
const shopMode = category === 'ecom_showcase' && (products.length >= 2 || hasCatalog);
const hero = params.hero ?? {};
---
<Base>
  {shopMode ? (
    <>
      <ShopControls />
      {(hero.headline || hero.cta_text) && (
        <div class="promo-strip">
          <div class="wrap promo-row">
            <span><strong>{hero.headline}</strong>{hero.subheadline ? ` — ${hero.subheadline}` : ''}</span>
            {hero.cta_text && (
              <a class="promo-cta" href={site.destination_url} data-outbound rel="nofollow sponsored">{hero.cta_text}</a>
            )}
          </div>
        </div>
      )}
      <ClaimsBar />
    </>
  ) : (
    <>
      <Hero />
      <ClaimsBar />
    </>
  )}

  {showTopDisclosure && (
    <div class="wrap">
      <div class="disclosure-note" set:html={marked.parse(disclosure)} />
    </div>
  )}

  {shopMode && hasCatalog && <style is:inline set:html={`#products{display:none}`} />}
  <main class={shopMode ? 'shop-main' : ''}>
    {shopMode && hasCatalog ? (
      <div id="sf-categories" class="sf-cats wrap">
        {catalogCategories.map((cat) => (
          <section class="sf-cat">
            <div class="sf-cat-head">
              <h2 class="sf-cat-title">{cat.title}</h2>
              <a class="sf-cat-all" href={href(`/category/${cat.slug}/`)}>See all {cat.title} ›</a>
            </div>
            <div class="sf-slider">
              {cat.products.map((p) => <ProductCard product={p} />)}
            </div>
          </section>
        ))}
      </div>
    ) : shopMode ? (
      <div id="sf-categories" class="sf-cats wrap" hidden></div>
    ) : null}
    {shopMode ? (
      <ShopGrid />
    ) : category === 'comparison' ? (
      <ComparisonTable />
    ) : category === 'lead_page' ? (
      <LeadForm />
    ) : (
      <ProductsGrid />
    )}

    {category === 'prelander' && (
      <section class="wrap" style="margin-top:34px">
        <article class="prose">
          <h2 class="section">{params.hero?.subheadline ?? 'Why readers choose this'}</h2>
          {Array.isArray(params.products) && params.products.length > 0 && (
            <p>
              After comparing the options, <strong>{params.products[0].title}</strong> stands
              out — <a href={params.products[0].target_url} data-outbound rel="nofollow sponsored">see current price</a>.
            </p>
          )}
        </article>
      </section>
    )}
  </main>

  <TrustFooter />
</Base>
