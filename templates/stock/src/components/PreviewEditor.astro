---
// WordPress-style inline content editor. Any element tagged [data-edit="param.path"]
// becomes editable when the page is opened with ?edit=1 (and, for publishing, an
// edit key from the panel). Mirrored spots [data-bind="name"] update live as their
// source [data-edit ... data-mirror="name"] changes. "Publish" saves the changed
// paths to the site's params via the panel and republishes the live site. Edits
// also persist in localStorage so the editor keeps them across reloads. Invisible
// to normal visitors (toolbar only appears with ?edit=1).
import { contentUrl, siteKey } from '../lib/config.js';
---
<button type="button" id="sf-edit-enter" class="sf-edit-enter" hidden>✏️ Edit this page</button>
<div id="sf-editbar" class="sf-editbar" data-content-url={contentUrl} data-site-key={siteKey} hidden>
  <span class="sf-editbar-title">✏️ Editing — click any highlighted text to change it.</span>
  <span id="sf-edit-status" class="sf-edit-status"></span>
  <span class="sf-editbar-actions">
    <button type="button" id="sf-edit-publish">Publish changes</button>
    <button type="button" id="sf-edit-copy">Copy JSON</button>
    <button type="button" id="sf-edit-discard">Discard</button>
    <button type="button" id="sf-edit-done">Done</button>
  </span>
</div>

<script is:inline>
(function () {
  function init() {
    var bar = document.getElementById('sf-editbar');
    if (!bar) return;
    var CONTENT_URL = bar.getAttribute('data-content-url') || '';
    var SITE_KEY = bar.getAttribute('data-site-key') || '';
    var LS_EDITS = 'sf-edits:' + SITE_KEY + ':' + location.pathname;
    var LS_KEY = 'sf-editkey:' + SITE_KEY;

    function fields() { return [].slice.call(document.querySelectorAll('[data-edit]')); }
    function setStatus(msg, kind) {
      var s = document.getElementById('sf-edit-status');
      if (s) { s.textContent = msg || ''; s.className = 'sf-edit-status' + (kind ? ' ' + kind : ''); }
    }
    function mirror(name, val) {
      if (!name) return;
      [].forEach.call(document.querySelectorAll('[data-bind="' + name + '"]'), function (el) { el.textContent = val; });
      if (name === 'phone') {
        var tel = 'tel:' + String(val).replace(/[^0-9+]/g, '');
        [].forEach.call(document.querySelectorAll('[data-bind-link="phone"]'), function (a) { a.setAttribute('href', tel); });
      }
    }

    // capture originals + apply any locally-saved edits
    var saved = {};
    try { saved = JSON.parse(localStorage.getItem(LS_EDITS) || '{}'); } catch (e) {}
    fields().forEach(function (el) {
      el.setAttribute('data-orig', el.textContent);
      var path = el.getAttribute('data-edit');
      if (saved[path] != null && String(saved[path]).length) el.textContent = saved[path];
      mirror(el.getAttribute('data-mirror'), el.textContent.trim());
    });

    function changed() {
      var out = {};
      fields().forEach(function (el) {
        var path = el.getAttribute('data-edit');
        var val = el.textContent.trim();
        if (val !== (el.getAttribute('data-orig') || '').trim()) out[path] = val;
      });
      return out;
    }
    function persist() {
      try { localStorage.setItem(LS_EDITS, JSON.stringify(changed())); } catch (e) {}
    }

    // capture an edit key passed in the URL (#k=...) then clean the address bar
    try {
      var m = (location.hash || '').match(/[#&]k=([^&]+)/);
      if (m) {
        localStorage.setItem(LS_KEY, decodeURIComponent(m[1]));
        history.replaceState(null, '', location.pathname + location.search);
      }
    } catch (e) {}

    var wantEdit = false;
    try { wantEdit = new URLSearchParams(location.search).get('edit') === '1'; } catch (e) {}
    var enterBtn = document.getElementById('sf-edit-enter');
    if (!wantEdit) {
      if (enterBtn) {
        enterBtn.hidden = false;
        enterBtn.addEventListener('click', function () {
          var u = new URL(location.href); u.searchParams.set('edit', '1'); location.href = u.toString();
        });
      }
      return;
    }
    if (enterBtn) enterBtn.hidden = true;

    document.body.classList.add('sf-editing');
    bar.hidden = false;
    fields().forEach(function (el) {
      el.setAttribute('contenteditable', 'true');
      el.classList.add('sf-editable');
      el.addEventListener('input', function () { mirror(el.getAttribute('data-mirror'), el.textContent.trim()); });
      el.addEventListener('blur', persist);
    });

    var editKey = '';
    try { editKey = localStorage.getItem(LS_KEY) || ''; } catch (e) {}
    var canPublish = !!(CONTENT_URL && SITE_KEY && editKey);

    var publishBtn = document.getElementById('sf-edit-publish');
    if (publishBtn) {
      if (!canPublish) {
        publishBtn.disabled = true;
        publishBtn.title = 'Open the edit link from your SiteFoundry panel to publish';
      }
      publishBtn.addEventListener('click', function () {
        persist();
        var edits = changed();
        if (!Object.keys(edits).length) { setStatus('No changes to publish.'); return; }
        publishBtn.disabled = true;
        setStatus('Publishing…');
        fetch(CONTENT_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ site_key: SITE_KEY, edit_key: editKey, edits: edits }),
        })
          .then(function (r) { return r.json().catch(function () { return {}; }).then(function (d) { return { ok: r.ok, d: d }; }); })
          .then(function (res) {
            if (res.ok && res.d && res.d.ok) {
              // saved edits are now the new baseline
              fields().forEach(function (el) { el.setAttribute('data-orig', el.textContent); });
              try { localStorage.removeItem(LS_EDITS); } catch (e) {}
              setStatus('Published! Your site updates in about a minute.', 'ok');
            } else if (res.d && res.d.rate_limited) {
              setStatus('Too many saves — wait a moment and try again.', 'err');
            } else {
              setStatus('Publish failed. Check your edit link and try again.', 'err');
            }
          })
          .catch(function () { setStatus('Publish failed — network error.', 'err'); })
          .then(function () { publishBtn.disabled = !canPublish ? true : false; });
      });
    }

    var copyBtn = document.getElementById('sf-edit-copy');
    if (copyBtn) copyBtn.addEventListener('click', function () {
      persist();
      var json = JSON.stringify(changed(), null, 2);
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(json).then(function () { setStatus('Copied changes to clipboard.'); }, function () { window.prompt('Copy:', json); });
      } else { window.prompt('Copy:', json); }
    });
    var discardBtn = document.getElementById('sf-edit-discard');
    if (discardBtn) discardBtn.addEventListener('click', function () {
      try { localStorage.removeItem(LS_EDITS); } catch (e) {}
      location.reload();
    });
    var doneBtn = document.getElementById('sf-edit-done');
    if (doneBtn) doneBtn.addEventListener('click', function () {
      persist();
      var u = new URL(location.href); u.searchParams.delete('edit'); location.href = u.toString();
    });
  }
  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);
})();
</script>
