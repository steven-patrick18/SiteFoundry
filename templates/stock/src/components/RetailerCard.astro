---
// Directory card linking to a store's on-site info page.
import { href } from '../lib/config.js';
const { retailer: r } = Astro.props;
const url = href(`/store/${r.slug}/`);
const initial = (r.name || '?').trim().charAt(0).toUpperCase();
---
<a
  class="rcard"
  href={url}
  data-name={r.name.toLowerCase()}
  data-category={r.category.toLowerCase()}
>
  <span class="rcard-logo" aria-hidden="true">{initial}</span>
  <span class="rcard-body">
    <span class="rcard-name">{r.name}</span>
    <span class="rcard-cat">{r.category}</span>
    <span class="rcard-tag">{r.tagline}</span>
    <span class="rcard-link">Contact &amp; info ›</span>
  </span>
</a>
