---
// Shopping-results chrome: compact sticky header (brand + search + sort)
// and a filter-chip row (On sale / Free delivery / per-store / price
// buckets) — the visual language of a shopping comparison page. All
// filtering is client-side over the static grid: zero network calls.
import { params, site } from '../lib/config.js';

const brand = params.brand ?? {};
const products = Array.isArray(params.products) ? params.products : [];

const stores = [
  ...new Set(
    products.flatMap((p) => [
      p.store_name,
      ...(Array.isArray(p.offers) ? p.offers.map((o) => o.store_name) : []),
    ]).filter(Boolean),
  ),
].slice(0, 6);

const hasSale = products.some((p) => p.compare_price);
const hasFreeShip = products.some(
  (p) =>
    /free/i.test(p.shipping_cost ?? '') ||
    (Array.isArray(p.offers) && p.offers.some((o) => /free/i.test(o.shipping_cost ?? ''))),
);
const searchUrl = site.search_url ?? '';
---
<header class="shop-top">
  <div class="wrap shop-top-row">
    <a class="shop-brand" href="/" aria-label={`${brand.business_name} home`}>
      {brand.logo_url ? <img src={brand.logo_url} alt={brand.business_name} /> : null}
      <span>{brand.business_name}</span>
    </a>
    <input
      id="sf-search-input"
      type="search"
      data-search-url={searchUrl}
      placeholder={searchUrl ? 'Search any product — live prices across stores…' : `Search ${products.length} products`}
      autocomplete="off"
      aria-label="Search products"
    />
    <select id="sf-search-sort" aria-label="Sort results">
      <option value="relevance">Sort: Best match</option>
      <option value="price-asc">Price: low to high</option>
      <option value="price-desc">Price: high to low</option>
      <option value="rating-desc">Top rated</option>
    </select>
  </div>
  <div class="wrap chips" id="sf-chips">
    <button class="chip active" data-chip="all">All</button>
    {hasSale && <button class="chip" data-chip="sale">On sale</button>}
    {hasFreeShip && <button class="chip" data-chip="freeship">Free delivery</button>}
    <button class="chip" data-chip="rated4">4★ &amp; up</button>
    {stores.map((store) => (
      <button class="chip" data-chip={`store:${String(store).toLowerCase()}`}>{store}</button>
    ))}
  </div>
</header>
<p id="sf-search-empty" class="search-empty wrap" hidden>
  No products match — try a different search or filter.
</p>

<!-- On-site product detail (keeps visitors on this site before the store) -->
<section id="sf-detail" class="sf-detail" hidden>
  <div class="wrap">
    <button type="button" class="sf-detail-back">← Back to results</button>
    <div class="sf-detail-main">
      <div class="sf-detail-media"><img id="sf-detail-img" src="" alt="" /></div>
      <div class="sf-detail-info">
        <h1 id="sf-detail-title"></h1>
        <div id="sf-detail-rating" class="grating"></div>
        <div id="sf-detail-price" class="sf-detail-price"></div>
        <div id="sf-detail-store" class="gstore"></div>
        <div id="sf-detail-deliv" class="gdelivery"></div>
        <a id="sf-detail-cta" class="cta sf-detail-cta" href="#" data-outbound rel="nofollow sponsored">Go to Store →</a>
        <p class="sub" style="margin-top:10px">You’ll be taken to the store to complete your purchase.</p>
      </div>
    </div>
    <h2 class="section" style="text-align:left;margin:28px 0 14px">You might also like</h2>
    <div id="sf-detail-related" class="ggrid"></div>
  </div>
</section>

<script is:inline>
(function () {
  'use strict';
  function init() {
    var input = document.getElementById('sf-search-input');
    var sort = document.getElementById('sf-search-sort');
    var chipsBox = document.getElementById('sf-chips');
    var empty = document.getElementById('sf-search-empty');
    var grid = document.querySelector('#products .ggrid');
    if (!input || !grid) return;
    var cards = [].slice.call(grid.querySelectorAll('.gcard'));
    var activeChip = 'all';
    var searchTimer = null;

    // ── live search mode (fetch products from the panel API) ──────────────
    var SEARCH_URL = input.getAttribute('data-search-url') || '';
    var originalGrid = grid.innerHTML; // baked-in catalog, restored when cleared
    var liveMode = false;
    var reqSeq = 0;

    function esc(s) {
      return String(s == null ? '' : s).replace(/[&<>"]/g, function (c) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c];
      });
    }
    function stars(r) {
      var n = Math.round(r || 0);
      return '★'.repeat(n) + '☆'.repeat(5 - n);
    }
    function compact(n) {
      if (!n) return '';
      return n >= 1000 ? (n / 1000).toFixed(n >= 10000 ? 0 : 1) + 'K' : String(n);
    }
    function priceNum(p) {
      var m = String(p == null ? '' : p).replace(/,/g, '').match(/[\d.]+/);
      return m ? m[0] : '';
    }
    function cardHtml(p) {
      var img = p.image_url
        ? '<img src="' + esc(p.image_url) + '" alt="" loading="lazy">'
        : '';
      var rating = typeof p.rating === 'number'
        ? '<div class="grating"><span class="gstars">' + stars(p.rating) + '</span><span>' +
          p.rating.toFixed(1) + '</span>' +
          (p.review_count ? '<span class="gcount">(' + compact(p.review_count) + ')</span>' : '') +
          '</div>'
        : '';
      var deliv = (p.shipping_cost || p.delivery_time)
        ? '<div class="gdelivery">' + esc([p.shipping_cost, p.delivery_time].filter(Boolean).join(' · ')) + '</div>'
        : '';
      var badge = p.badge ? '<span class="badge-chip">' + esc(p.badge) + '</span>' : '';
      var cmp = p.compare_price ? '<s>' + esc(p.compare_price) + '</s>' : '';
      return '<div class="gcard" data-json="' + esc(JSON.stringify(p)) + '" data-price="' + esc(priceNum(p.price)) + '" data-rating="' +
        (p.rating || '') + '" data-sale="' + (p.compare_price ? '1' : '0') + '" data-freeship="' +
        (/free/i.test(p.shipping_cost || '') ? '1' : '0') + '" data-stores="' + esc((p.store_name || '').toLowerCase()) + '">' +
        '<a class="gimg" href="' + esc(p.link) + '" data-outbound data-product="' + esc(p.title) + '" rel="nofollow sponsored">' + badge + img + '</a>' +
        '<div class="gbody">' +
        '<a class="gtitle" href="' + esc(p.link) + '" data-outbound data-product="' + esc(p.title) + '" rel="nofollow sponsored">' + esc(p.title) + '</a>' +
        '<div class="gprice"><span class="amount">' + esc(p.price || '') + '</span>' + cmp + '</div>' +
        rating +
        (p.store_name ? '<div class="gstore">' + esc(p.store_name) + '</div>' : '') +
        deliv +
        '<a class="gvisit" href="' + esc(p.link) + '" data-outbound data-product="' + esc(p.title) + '" rel="nofollow sponsored">Visit store ›</a>' +
        '</div></div>';
    }

    function runLiveSearch(q) {
      var seq = ++reqSeq;
      grid.innerHTML = '<p class="sub" style="grid-column:1/-1;padding:20px">Searching stores…</p>';
      liveMode = true;
      fetch(SEARCH_URL + '?q=' + encodeURIComponent(q) + '&gl=us')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (seq !== reqSeq) return; // a newer search superseded this one
          var list = (data && data.results) || [];
          if (!list.length) {
            grid.innerHTML = '<p class="sub" style="grid-column:1/-1;padding:20px">' +
              (data && data.capped ? 'Search limit reached for now — try again later.' : 'No live results for “' + esc(q) + '”. Try another product.') +
              '</p>';
          } else {
            grid.innerHTML = list.map(cardHtml).join('');
          }
          cards = [].slice.call(grid.querySelectorAll('.gcard'));
          applySort();
        })
        .catch(function () {
          if (seq !== reqSeq) return;
          grid.innerHTML = '<p class="sub" style="grid-column:1/-1;padding:20px">Search is unavailable right now.</p>';
        });
    }

    function restoreCatalog() {
      liveMode = false;
      grid.innerHTML = originalGrid;
      cards = [].slice.call(grid.querySelectorAll('.gcard'));
      if (empty) empty.hidden = true;
    }

    function matchChip(card) {
      if (activeChip === 'all') return true;
      if (activeChip === 'sale') return card.getAttribute('data-sale') === '1';
      if (activeChip === 'freeship') return card.getAttribute('data-freeship') === '1';
      if (activeChip === 'rated4') return (parseFloat(card.getAttribute('data-rating')) || 0) >= 4;
      if (activeChip.indexOf('store:') === 0) {
        var store = activeChip.slice(6);
        return (card.getAttribute('data-stores') || '').indexOf(store) !== -1;
      }
      return true;
    }

    function matchSearch(card, terms) {
      if (!terms.length) return true;
      var hay = card.getAttribute('data-search') || '';
      for (var i = 0; i < terms.length; i++) {
        if (hay.indexOf(terms[i]) === -1) return false;
      }
      return true;
    }

    function applySort() {
      var mode = sort ? sort.value : 'relevance';
      var ordered = cards.slice();
      if (mode !== 'relevance') {
        ordered.sort(function (a, b) {
          var pa = parseFloat(a.getAttribute('data-price')) || 0;
          var pb = parseFloat(b.getAttribute('data-price')) || 0;
          var ra = parseFloat(a.getAttribute('data-rating')) || 0;
          var rb = parseFloat(b.getAttribute('data-rating')) || 0;
          if (mode === 'price-asc') return pa - pb;
          if (mode === 'price-desc') return pb - pa;
          return rb - ra;
        });
      }
      ordered.forEach(function (card, i) { card.style.order = String(i); });
    }

    function apply() {
      // In live mode the API already matched the query; only chips filter.
      var terms = liveMode ? [] : input.value.toLowerCase().split(/\s+/).filter(Boolean);
      var visible = 0;
      cards.forEach(function (card) {
        var show = matchChip(card) && matchSearch(card, terms);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (empty) empty.hidden = visible !== 0 || liveMode;
      applySort();
    }

    input.addEventListener('input', function () {
      var q = input.value.trim();
      clearTimeout(searchTimer);
      if (SEARCH_URL) {
        // live mode: debounce, then fetch real products from the panel API
        if (q.length < 2) { restoreCatalog(); return; }
        searchTimer = setTimeout(function () {
          runLiveSearch(q);
          if (window.sfTrack) window.sfTrack('search', { q: q.slice(0, 120) });
        }, 500);
      } else {
        // no search endpoint: filter the baked-in catalog locally
        apply();
        if (q.length >= 2 && window.sfTrack) {
          searchTimer = setTimeout(function () {
            window.sfTrack('search', { q: q.slice(0, 120) });
          }, 700);
        }
      }
    });
    if (sort) sort.addEventListener('change', apply);
    if (chipsBox) {
      chipsBox.addEventListener('click', function (e) {
        var chip = e.target.closest('.chip');
        if (!chip) return;
        activeChip = chip.getAttribute('data-chip');
        [].forEach.call(chipsBox.querySelectorAll('.chip'), function (c) {
          c.classList.toggle('active', c === chip);
        });
        apply();
      });
    }

    // ── on-site product detail (keeps visitors on this site) ──────────────
    var detail = document.getElementById('sf-detail');
    var productsSection = document.getElementById('products');

    function openDetail(p) {
      if (!detail) return;
      var link = p.link || p.target_url || '#';
      detail.querySelector('#sf-detail-img').src = p.image_url || '';
      detail.querySelector('#sf-detail-img').style.display = p.image_url ? '' : 'none';
      detail.querySelector('#sf-detail-title').textContent = p.title || '';
      detail.querySelector('#sf-detail-price').innerHTML =
        '<span class="amount">' + esc(p.price || '') + '</span>' +
        (p.compare_price ? ' <s>' + esc(p.compare_price) + '</s>' : '');
      detail.querySelector('#sf-detail-rating').innerHTML =
        typeof p.rating === 'number'
          ? '<span class="gstars">' + stars(p.rating) + '</span> ' + p.rating.toFixed(1) +
            (p.review_count ? ' <span class="gcount">(' + compact(p.review_count) + ')</span>' : '')
          : '';
      detail.querySelector('#sf-detail-store').textContent = p.store_name || '';
      detail.querySelector('#sf-detail-deliv').textContent =
        [p.shipping_cost, p.delivery_time].filter(Boolean).join(' · ');
      var cta = detail.querySelector('#sf-detail-cta');
      cta.href = link;
      cta.setAttribute('data-product', p.title || '');

      // related = the other cards currently shown
      var related = cards.filter(function (c) { return c.getAttribute('data-json') && c.querySelector('.gtitle') && c.querySelector('.gtitle').textContent !== p.title; }).slice(0, 5);
      var rel = detail.querySelector('#sf-detail-related');
      rel.innerHTML = related.map(function (c) { return c.outerHTML; }).join('');

      if (productsSection) productsSection.style.display = 'none';
      detail.hidden = false;
      window.scrollTo({ top: 0, behavior: 'smooth' });
      try { history.pushState({ sfDetail: 1 }, ''); } catch (e) {}
      if (window.sfTrack) window.sfTrack('cta_click', { product: p.title, step: 'detail_view' });
    }

    function closeDetail() {
      if (!detail) return;
      detail.hidden = true;
      if (productsSection) productsSection.style.display = '';
    }

    function cardProduct(card) {
      var raw = card.getAttribute('data-json');
      if (!raw) return null;
      try { return JSON.parse(raw); } catch (e) { return null; }
    }

    // intercept product clicks anywhere in the grid or related strip
    document.addEventListener('click', function (e) {
      var goStore = e.target.closest('.sf-detail-cta');
      if (goStore) return; // let the outbound link (and sf.js) handle it
      var card = e.target.closest('.gcard');
      if (!card) return;
      var p = cardProduct(card);
      if (!p) return; // baked-in cards without json fall through to their links
      e.preventDefault();
      openDetail(p);
    }, true);

    if (detail) {
      detail.querySelector('.sf-detail-back').addEventListener('click', function () {
        try { history.back(); } catch (e) { closeDetail(); }
      });
    }
    window.addEventListener('popstate', function () {
      if (detail && !detail.hidden) closeDetail();
    });
  }
  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);
})();
</script>
