---
// Shopping-style comparison: seller, rating, price, delivery, highlights —
// the columns a US comparison shopper expects, with a recommended pick row.
import { params } from '../lib/config.js';
import OfferMeta from './OfferMeta.astro';
import Offers from './Offers.astro';
const products = Array.isArray(params.products) ? params.products : [];
const cta = params.hero?.cta_text ?? 'Check Price';
---
{products.length > 0 && (
  <section class="wrap" id="comparison">
    <h2 class="section">Compared side by side</h2>
    <div class="compare-scroll">
      <table class="compare">
        <thead>
          <tr><th>Option</th><th>Price</th><th>Delivery</th><th>Highlights</th><th></th></tr>
        </thead>
        <tbody>
          {products.map((p, i) => (
            <tr class={i === 0 ? 'pick' : ''}>
              <td>
                <div class="compare-option">
                  <span class="rank">#{i + 1}</span>
                  {p.image_url && <img class="thumb" src={p.image_url} alt="" loading="lazy" />}
                  <div>
                    <strong>{p.title}</strong>
                    {i === 0 && <span class="pick-badge">Our pick</span>}
                    {p.badge && i !== 0 && <span class="badge-chip inline">{p.badge}</span>}
                    <OfferMeta product={p} />
                    <Offers product={p} cta="Go" />
                  </div>
                </div>
              </td>
              <td>
                <div class="price">
                  {p.price}
                  {p.compare_price && <s>{p.compare_price}</s>}
                </div>
              </td>
              <td class="delivery-cell">
                {p.shipping_cost && <div class="ship">{p.shipping_cost}</div>}
                {p.delivery_time && <div>{p.delivery_time}</div>}
                {!p.shipping_cost && !p.delivery_time && '—'}
              </td>
              <td>
                {Array.isArray(p.bullets) && (
                  <ul style="padding-left:16px">
                    {p.bullets.map((b) => <li>{b}</li>)}
                  </ul>
                )}
              </td>
              <td><a class="cta" style="padding:9px 18px;font-size:14px;white-space:nowrap" href={p.target_url} data-outbound data-product={p.title} rel="nofollow sponsored">{cta}</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
)}
