---
// Base layout: SEO head, tracking injection, brand CSS vars, sf.js beacon.
// No blocking pop-ups/gates ever (protects ad account health — spec §1).
import { params, site, href } from '../lib/config.js';
import PreviewEditor from '../components/PreviewEditor.astro';

const { title, description } = Astro.props;
const brand = params.brand ?? {};
const seo = params.seo ?? {};
const t = site.tracking ?? {};
const pageTitle = title ?? seo.page_title ?? brand.business_name;
const pageDescription = description ?? seo.meta_description ?? '';
const fontStack = `${brand.font ?? 'Inter'}, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    {seo.og_image_url && <meta property="og:image" content={seo.og_image_url} />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <link rel="canonical" href={`https://${site.domain}${Astro.url.pathname}`} />

    {/* ── First-party beacon (SiteFoundry sf.js) ── */}
    <script
      src={href('/sf.js')}
      data-site-key={site.site_key ?? site.domain}
      data-dest={site.destination_url}
      data-track={site.track_url ?? ''}
      defer
    ></script>

    {/* ── Google Analytics 4 ── */}
    {t.ga4_id && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${t.ga4_id}`}></script>
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${t.ga4_id}');${t.google_ads_conversion_id ? `gtag('config','${t.google_ads_conversion_id}');` : ''}`}></script>
      </>
    )}
    {/* ── Google Ads (when no GA4 present) ── */}
    {!t.ga4_id && t.google_ads_conversion_id && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${t.google_ads_conversion_id}`}></script>
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${t.google_ads_conversion_id}');`}></script>
      </>
    )}
    {/* ── Meta Pixel ── */}
    {t.meta_pixel_id && (
      <script is:inline set:html={`!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','${t.meta_pixel_id}');fbq('track','PageView');`}></script>
    )}
    {/* ── Microsoft/Bing UET ── */}
    {t.bing_uet_tag && (
      <script is:inline set:html={`(function(w,d,t,r,u){var f,n,i;w[u]=w[u]||[],f=function(){var o={ti:"${t.bing_uet_tag}",enableAutoSpaTracking:true};o.q=w[u],w[u]=new UET(o),w[u].push("pageLoad")},n=d.createElement(t),n.src=r,n.async=1,n.onload=n.onreadystatechange=function(){var s=this.readyState;s&&s!=="loaded"&&s!=="complete"||(f(),n.onload=n.onreadystatechange=null)},i=d.getElementsByTagName(t)[0],i.parentNode.insertBefore(n,i)})(window,document,"script","//bat.bing.com/bat.js","uetq");`}></script>
    )}
    {/* ── PushVault (push capture) — real CDN snippet when configured ── */}
    {t.pushvault_property_key && (
      <script
        src={site.pushvault_cdn ? `${site.pushvault_cdn}/pushvault.js` : href('/pushvault.js')}
        data-property-key={t.pushvault_property_key}
        defer
      ></script>
    )}

    {/* Per-page head extras — structured data (JSON-LD) from product/category pages */}
    <slot name="head" />
  </head>
  <body>
    <slot />
    <PreviewEditor />
    <style is:global define:vars={{ primary: brand.primary_color ?? '#4f46e5', secondary: brand.secondary_color ?? '#22c55e', fontStack }}>
      * { box-sizing: border-box; margin: 0; }
      body { font-family: var(--fontStack); color: #111827; background: #fff; line-height: 1.55; }
      .wrap { max-width: 1080px; margin: 0 auto; padding: 0 20px; }
      header.hero { background: linear-gradient(160deg, var(--primary), color-mix(in srgb, var(--primary) 60%, #000)); color: #fff; padding: 64px 0 56px; text-align: center; }
      header.hero img.logo { height: 44px; margin-bottom: 18px; }
      header.hero h1 { font-size: clamp(28px, 5vw, 44px); line-height: 1.15; margin-bottom: 12px; }
      header.hero p.sub { font-size: clamp(15px, 2.4vw, 19px); opacity: .92; max-width: 640px; margin: 0 auto 26px; }
      .cta { display: inline-block; background: var(--secondary); color: #06230f; font-weight: 700; padding: 14px 34px; border-radius: 10px; text-decoration: none; font-size: 17px; }
      .cta:hover { filter: brightness(1.06); }
      .claims { background: #f3f6ff; padding: 14px 0; }
      .claims ul { display: flex; flex-wrap: wrap; gap: 10px 26px; justify-content: center; list-style: none; padding: 0; }
      .claims li { font-size: 14px; font-weight: 600; color: #1f2937; }
      .claims li::before { content: '✓ '; color: var(--secondary); }
      main { padding: 46px 0; }
      h2.section { text-align: center; font-size: 26px; margin-bottom: 26px; }
      .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 20px; }
      .product { border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; display: flex; flex-direction: column; position: relative; }
      .badge-chip { position: absolute; top: 10px; left: 10px; background: #1f2937; color: #fff; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 999px; z-index: 1; }
      .badge-chip.inline { position: static; display: inline-block; margin-left: 8px; background: #eef2ff; color: #3730a3; }
      .rating { display: flex; align-items: center; gap: 5px; font-size: 13px; }
      .stars { color: #f59e0b; letter-spacing: 1px; font-size: 13.5px; }
      .rating-num { font-weight: 600; color: #374151; }
      .reviews { color: #6b7280; }
      .store { font-size: 12.5px; color: #4b5563; }
      .delivery { font-size: 12.5px; color: #15803d; font-weight: 500; }
      .delivery .ship { font-weight: 700; }
      .compare-scroll { overflow-x: auto; }
      .search-empty { color: #6b7280; font-size: 14px; padding: 10px 0 0; }

      /* ── shopping-results chrome (Google-Shopping-style layout) ── */
      .shop-top { background: #fff; border-bottom: 1px solid #ebebeb; position: sticky; top: 0; z-index: 30; }
      .shop-top-row { display: flex; align-items: center; gap: 14px; padding-top: 10px; padding-bottom: 10px; }
      .shop-brand { display: flex; align-items: center; gap: 8px; text-decoration: none; color: #202124; font-weight: 700; font-size: 17px; white-space: nowrap; }
      .shop-brand img { height: 26px; }
      .shop-top input[type=search] { flex: 1; height: 42px; padding: 0 18px; border: 1px solid #dfe1e5; border-radius: 21px; font-size: 15px; background: #f8f9fa; outline: none; }
      .shop-top input[type=search]:focus { background: #fff; border-color: #dfe1e5; box-shadow: 0 1px 6px rgba(32,33,36,.18); }
      .shop-top select { height: 42px; border: 1px solid #dfe1e5; border-radius: 8px; padding: 0 10px; font-size: 13.5px; background: #fff; color: #3c4043; }
      .sf-header-search { flex: 1; display: flex; }
      .sf-header-search input[type=search] { width: 100%; }

      /* ── multipage: breadcrumb + product & category pages ── */
      .breadcrumb { font-size: 13px; color: #70757a; padding: 14px 0 0; display: flex; gap: 7px; flex-wrap: wrap; }
      .breadcrumb a { color: #1a73e8; text-decoration: none; }
      .breadcrumb a:hover { text-decoration: underline; }
      .breadcrumb .sep { color: #bdc1c6; }
      .pdp { padding: 8px 0 40px; }
      .pdp-main { display: flex; gap: 40px; align-items: flex-start; margin-top: 16px; flex-wrap: wrap; }
      .pdp-media { flex: 0 0 380px; max-width: 100%; background: #f8f9fa; border-radius: 14px; padding: 28px; text-align: center; }
      .pdp-media img { max-width: 100%; max-height: 380px; object-fit: contain; }
      .pdp-info { flex: 1; min-width: 280px; }
      .pdp-info h1 { font-size: 26px; line-height: 1.25; margin-bottom: 12px; }
      .pdp-price { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; margin: 14px 0; }
      .pdp-price .amount { font-size: 30px; font-weight: 700; color: #202124; }
      .pdp-price s { color: #70757a; font-size: 18px; }
      .pdp-price .save { background: #e6f4ea; color: #188038; font-weight: 700; font-size: 13px; padding: 3px 10px; border-radius: 6px; }
      .pdp-meta { color: #5f6368; font-size: 14px; margin: 6px 0; }
      .pdp-meta .store { color: #202124; font-weight: 600; }
      .pdp-cta { margin-top: 20px; display: inline-block; font-size: 16px; padding: 14px 34px; }
      .pdp-note { color: #70757a; font-size: 13px; margin-top: 10px; }
      .pdp-section { margin: 36px 0 0; }
      .pdp-section h2 { font-size: 19px; margin-bottom: 12px; }
      .pdp-specs { width: 100%; border-collapse: collapse; font-size: 14px; max-width: 560px; }
      .pdp-specs td { padding: 10px 12px; border-top: 1px solid #eef0f2; }
      .pdp-specs td:first-child { color: #70757a; width: 40%; }
      .faq-q { font-weight: 600; margin: 16px 0 4px; }
      .faq-a { color: #3c4043; font-size: 14.5px; }
      .cat-head { padding: 10px 0 0; }
      .cat-head h1 { font-size: 26px; margin: 6px 0 8px; text-transform: capitalize; }
      .cat-intro { color: #5f6368; font-size: 15px; max-width: 720px; margin-bottom: 20px; }
      .sf-empty-home { padding: 56px 20px; text-align: center; color: #5f6368; font-size: 17px; }

      /* ── US retailers directory template ── */
      .dir-hero { background: linear-gradient(180deg, color-mix(in srgb, var(--primary) 10%, #fff), #fff); border-bottom: 1px solid #ebebeb; padding: 26px 0 22px; }
      .dir-brand { display: inline-block; font-weight: 700; color: var(--primary); text-decoration: none; font-size: 15px; margin-bottom: 12px; }
      .dir-hero h1 { font-size: 30px; line-height: 1.2; max-width: 820px; }
      .dir-hero-sub { color: #4b5563; font-size: 16px; max-width: 720px; margin-top: 10px; }
      .dir-search { margin: 18px 0 12px; }
      .dir-search input { width: 100%; max-width: 560px; height: 46px; padding: 0 20px; border: 1px solid #dfe1e5; border-radius: 23px; font-size: 15px; background: #fff; outline: none; }
      .dir-search input:focus { border-color: var(--primary); box-shadow: 0 1px 8px rgba(32,33,36,.15); }
      .dir-chips { display: flex; flex-wrap: wrap; gap: 8px; }
      .dir-main { padding: 26px 20px 44px; }
      .dir-empty { padding: 30px 0; color: #70757a; }
      .dir-cat { margin: 0 0 30px; }
      .dir-cat-head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 14px; border-bottom: 1px solid #eef0f2; padding-bottom: 8px; }
      .dir-cat-head h2 { font-size: 20px; }
      .dir-cat-all { color: var(--primary); font-size: 13.5px; font-weight: 600; text-decoration: none; white-space: nowrap; }
      .dir-cat-all:hover { text-decoration: underline; }
      .rgrid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px; }
      .rcard { display: flex; gap: 14px; align-items: flex-start; background: #fff; border: 1px solid #e8eaed; border-radius: 12px; padding: 16px; text-decoration: none; color: inherit; transition: box-shadow .15s, border-color .15s, transform .1s; }
      .rcard:hover { border-color: #d2d5da; box-shadow: 0 3px 14px rgba(32,33,36,.1); transform: translateY(-1px); }
      .rcard-logo { flex: 0 0 46px; width: 46px; height: 46px; border-radius: 10px; background: color-mix(in srgb, var(--primary) 14%, #fff); color: var(--primary); font-weight: 800; font-size: 22px; display: flex; align-items: center; justify-content: center; }
      .rcard-body { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
      .rcard-name { font-weight: 700; font-size: 16px; color: #202124; }
      .rcard-cat { font-size: 12px; color: var(--primary); font-weight: 600; text-transform: uppercase; letter-spacing: .3px; }
      .rcard-tag { font-size: 13px; color: #5f6368; margin-top: 3px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
      .rcard-link { font-size: 13px; color: var(--primary); font-weight: 600; margin-top: 6px; }
      .dir-about { margin-top: 30px; max-width: 860px; }
      .dir-about h2 { font-size: 22px; margin-bottom: 12px; }
      .dir-about p { margin-bottom: 14px; color: #3c4043; }
      .dir-disclaimer { font-size: 13px; color: #70757a; background: #f8f9fa; border: 1px solid #eef0f2; border-radius: 10px; padding: 14px 16px; }

      /* store detail page */
      .store-page { padding: 6px 20px 44px; }
      .store-hd { display: flex; gap: 16px; align-items: center; margin: 14px 0 8px; }
      .store-logo { flex: 0 0 60px; width: 60px; height: 60px; border-radius: 14px; background: color-mix(in srgb, var(--primary) 14%, #fff); color: var(--primary); font-weight: 800; font-size: 30px; display: flex; align-items: center; justify-content: center; }
      .store-hd h1 { font-size: 25px; line-height: 1.25; }
      .store-tag { color: #5f6368; font-size: 15px; margin-top: 4px; }
      .store-cols { display: flex; gap: 34px; align-items: flex-start; margin-top: 18px; flex-wrap: wrap; }
      .store-main { flex: 1; min-width: 300px; }
      .store-main .prose { margin-bottom: 26px; }
      .store-main h2 { font-size: 20px; margin-bottom: 10px; }
      .store-main p { color: #3c4043; margin-bottom: 12px; }
      .store-main ul { margin: 0 0 12px 20px; color: #3c4043; }
      .store-main li { margin-bottom: 6px; }
      .store-tags { display: flex; flex-wrap: wrap; gap: 8px; }
      .store-chip { background: #f1f3f4; color: #3c4043; font-size: 13px; padding: 5px 12px; border-radius: 999px; }
      .store-faq h3 { font-size: 16px; }
      .store-side { flex: 0 0 300px; max-width: 100%; position: sticky; top: 78px; }
      .store-card { background: #fff; border: 1px solid #e8eaed; border-radius: 14px; padding: 20px; box-shadow: 0 2px 10px rgba(32,33,36,.05); }
      .store-card-h { font-size: 16px; margin-bottom: 12px; }
      .store-facts { margin: 0; }
      .store-facts dt { font-size: 12px; color: #70757a; text-transform: uppercase; letter-spacing: .3px; margin-top: 10px; }
      .store-facts dd { font-size: 15px; color: #202124; font-weight: 600; }
      .store-cta { display: block; text-align: center; margin-top: 18px; }
      .store-note { font-size: 12px; color: #9aa0a6; text-align: center; margin-top: 8px; }
      .store-related { margin-top: 20px; }
      .store-related h2 { font-size: 20px; margin-bottom: 14px; }
      @media (max-width: 760px) { .store-side { position: static; flex-basis: 100%; } .dir-hero h1 { font-size: 24px; } }

      /* store customer-service banner (top of every brand page) */
      .store-banner { background: color-mix(in srgb, var(--primary) 12%, #fff); border-bottom: 1px solid color-mix(in srgb, var(--primary) 22%, #fff); }
      .store-banner-row { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 10px 0; flex-wrap: wrap; }
      .store-banner-txt { font-size: 15px; color: #202124; }
      .store-banner-ico { margin-right: 6px; }
      .store-banner-num { color: var(--primary); font-weight: 800; text-decoration: none; font-size: 16px; }
      .store-banner-num:hover { text-decoration: underline; }
      .store-banner-cta { flex: 0 0 auto; background: var(--primary); color: #fff; font-weight: 700; font-size: 13px; padding: 7px 16px; border-radius: 999px; text-decoration: none; white-space: nowrap; }

      /* inline content editor (operator-only; activated via the panel link) */
      .sf-editbar { position: fixed; left: 0; right: 0; bottom: 0; z-index: 70; background: #202124; color: #fff; display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 12px 20px; flex-wrap: wrap; box-shadow: 0 -4px 16px rgba(0,0,0,.25); }
      .sf-editbar-title { font-size: 14px; }
      .sf-edit-status { font-size: 13px; color: #9aa0a6; margin-left: auto; }
      .sf-edit-status.ok { color: #81c995; }
      .sf-edit-status.err { color: #f28b82; }
      .sf-editbar-actions { display: flex; gap: 8px; }
      .sf-editbar button { background: #3c4043; color: #fff; border: 1px solid #5f6368; border-radius: 8px; padding: 8px 14px; font-size: 13px; font-weight: 600; cursor: pointer; }
      .sf-editbar button:disabled { opacity: .5; cursor: not-allowed; }
      .sf-editbar #sf-edit-publish { background: var(--secondary); border-color: var(--secondary); color: #06280f; }
      body.sf-editing { padding-bottom: 64px; }
      body.sf-editing [data-edit] { outline: 2px dashed color-mix(in srgb, var(--primary) 60%, #fff); outline-offset: 3px; border-radius: 3px; cursor: text; transition: background .1s; }
      body.sf-editing [data-edit]:hover { background: color-mix(in srgb, var(--primary) 8%, #fff); }
      body.sf-editing [data-edit]:focus { outline: 2px solid var(--primary); background: #fff; }
      .chips { display: flex; gap: 8px; overflow-x: auto; padding-top: 2px; padding-bottom: 10px; scrollbar-width: none; }
      .chips::-webkit-scrollbar { display: none; }
      .chip { flex-shrink: 0; border: 1px solid #dadce0; background: #fff; color: #3c4043; font-size: 13px; padding: 6px 14px; border-radius: 999px; cursor: pointer; }
      .chip:hover { background: #f8f9fa; }
      .chip.active { background: #e8f0fe; border-color: #d2e3fc; color: #1967d2; font-weight: 600; }
      .promo-strip { background: color-mix(in srgb, var(--primary) 8%, #fff); border-bottom: 1px solid #ebebeb; font-size: 13.5px; color: #202124; }
      .promo-row { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding-top: 8px; padding-bottom: 8px; }
      .promo-cta { background: var(--primary); color: #fff; font-weight: 600; font-size: 12.5px; padding: 6px 16px; border-radius: 999px; text-decoration: none; white-space: nowrap; }
      .shop-main { padding: 18px 0 46px; }
      .shop-main .claims { background: none; }

      /* ── category home (auto-created rows + horizontal sliders) ── */
      .sf-cats { padding: 8px 0 0; }
      .sf-cat { margin: 6px 0 26px; }
      .sf-cat-head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin: 0 0 12px; }
      .sf-cat-title { font-size: 20px; font-weight: 700; color: #202124; text-transform: capitalize; margin: 0; }
      .sf-cat-all { background: none; border: 0; color: #1a73e8; font-size: 13.5px; font-weight: 600; cursor: pointer; white-space: nowrap; padding: 4px 0; }
      .sf-cat-all:hover { text-decoration: underline; }
      .sf-slider { display: flex; gap: 10px; overflow-x: auto; scroll-snap-type: x mandatory; padding: 2px 2px 12px; -webkit-overflow-scrolling: touch; scrollbar-width: thin; }
      .sf-slider::-webkit-scrollbar { height: 8px; }
      .sf-slider::-webkit-scrollbar-thumb { background: #dadce0; border-radius: 999px; }
      .sf-slider .gcard { flex: 0 0 auto; width: 190px; scroll-snap-align: start; border-color: #ebebeb; }
      @media (max-width: 640px) { .sf-slider .gcard { width: 150px; } .sf-cat-title { font-size: 17px; } .sf-slider .gimg { height: 130px; } }

      /* ── shopping cards ── */
      .ggrid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 8px; }
      .gcard { background: #fff; border: 1px solid transparent; border-radius: 12px; padding: 10px; display: flex; flex-direction: column; transition: box-shadow .15s, border-color .15s; }
      .gcard:hover { border-color: #ebebeb; box-shadow: 0 1px 10px rgba(32,33,36,.12); }
      .gimg { display: block; height: 190px; text-align: center; }
      .gimg img { width: 100%; height: 100%; object-fit: contain; border-radius: 8px; }
      .gbody { display: flex; flex-direction: column; gap: 3px; padding-top: 8px; }
      .gtitle { color: #202124; font-size: 13.5px; line-height: 1.35; text-decoration: none; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 2.7em; }
      .gtitle:hover { text-decoration: underline; }
      .gprice { display: flex; align-items: baseline; gap: 7px; flex-wrap: wrap; }
      .gprice .amount { font-size: 18px; font-weight: 600; color: #202124; }
      .gprice s { color: #70757a; font-size: 12.5px; }
      .gdeal { color: #d93025; font-size: 11px; font-weight: 700; letter-spacing: .3px; text-transform: uppercase; }
      .grating { display: flex; align-items: center; gap: 5px; font-size: 12.5px; color: #70757a; }
      .gstars { color: #fbbc04; font-size: 13px; letter-spacing: .5px; }
      .gcount { color: #70757a; }
      .gstore { font-size: 12.5px; color: #70757a; }
      .gdelivery { font-size: 12.5px; color: #188038; font-weight: 500; }
      .gvisit { margin-top: 6px; color: #1a73e8; font-size: 13px; font-weight: 600; text-decoration: none; }
      .gvisit:hover { text-decoration: underline; }
      .gcard .offers { margin: 6px 0 0; border-color: #ebebeb; }
      .gcard .offers summary { color: #1a73e8; font-weight: 500; font-size: 12.5px; padding: 7px 10px; }
      /* on-site product detail */
      .sf-detail { padding: 20px 0 50px; }
      .sf-detail-back { background: none; border: 0; color: #1a73e8; font-size: 14px; cursor: pointer; padding: 6px 0; }
      .sf-detail-back:hover { text-decoration: underline; }
