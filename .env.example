# Copy to .env and adjust. Defaults match docker-compose.yml.

NODE_ENV=development
PORT=3000

# PostgreSQL 15
DATABASE_URL=postgresql://sitefoundry:sitefoundry@localhost:5432/sitefoundry

# Redis 7 (BullMQ)
REDIS_URL=redis://localhost:6379

# S3 (MinIO locally) — build artifacts + template packages + images
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=sitefoundry
S3_KEY=minioadmin
S3_SECRET=minioadmin

# KMS (LocalStack locally, AWS KMS in prod) — credential vault master key
# Create the dev key with:
#   awslocal kms create-key --description "sitefoundry-dev-master"
KMS_ENDPOINT=http://localhost:4566
KMS_MASTER_KEY_ID=
KMS_REGION=us-east-1

# Secrets — replace in any real deployment
JWT_SECRET=dev-only-jwt-secret
INTERNAL_SECRET=dev-only-internal-secret

# URLs
APP_BASE_URL=http://localhost:5173
CDN_BASE_URL=http://localhost:9000/sitefoundry

# SerpApi key for the wizard's Product Finder (serpapi.com — optional).
# Results are cached locally; imported products live in the static site,
# so visitors never consume API credits.
SERPAPI_KEY=
