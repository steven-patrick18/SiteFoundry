{
  "name": "sitefoundry",
  "version": "0.1.0",
  "private": true,
  "description": "SiteFoundry — server-connected landing site deployment platform",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @sitefoundry/api --filter @sitefoundry/dashboard --parallel dev",
    "worker": "pnpm --filter @sitefoundry/api worker",
    "build": "pnpm -r build",
    "seed": "tsx prisma/seed.ts",
    "prisma": "prisma"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
