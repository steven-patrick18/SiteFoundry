// SiteFoundry database schema — Milestone M1 tables (§3 of the build doc):
// tenants, users, credentials, servers, deploy_events, audit_log.
// Sites/builds/templates/clients land with M2–M3; visits/leads with M4–M5.
//
// Every tenant table carries tenant_id; RLS policies (enable + force +
// tenant_isolation) are applied in the *_rls migration. The API runs as the
// restricted `sitefoundry_app` role — only migrations/seed use the owner role.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  brandName         String?  @map("brand_name")
  brandLogoUrl      String?  @map("brand_logo_url")
  brandPrimaryColor String?  @map("brand_primary_color")
  customDomain      String?  @map("custom_domain")
  plan              String   @default("internal") // internal|starter|agency|enterprise
  status            String   @default("active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  users        User[]
  credentials  Credential[]
  servers      Server[]
  deployEvents DeployEvent[]
  auditLogs    AuditLog[]
  clients      Client[]
  templates    Template[]
  sites         Site[]
  builds        Build[]
  campaignLinks CampaignLink[]
  leads         Lead[]

  @@map("tenants")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         String // admin|builder|viewer
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("users")
}

model Credential {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  kind        String // ssh_private_key|ssh_password|oauth_token|api_token
  label       String
  ciphertext  Bytes // AES-256-GCM encrypted secret — NEVER returned by any endpoint
  dekWrapped  Bytes     @map("dek_wrapped") // DEK wrapped by KMS master key
  iv          Bytes
  authTag     Bytes     @map("auth_tag")
  fingerprint String? // SSH key SHA256 fingerprint (safe to show)
  createdBy   String?   @map("created_by") @db.Uuid
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz()
  rotatedAt   DateTime? @map("rotated_at") @db.Timestamptz()
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  servers Server[]

  @@index([tenantId])
  @@map("credentials")
}

model Server {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String
  host            String
  port            Int       @default(22)
  sshUsername     String    @map("ssh_username")
  authType        String    @map("auth_type") // ssh_key|password
  credentialId    String    @map("credential_id") @db.Uuid
  provider        String? // hetzner|aws|contabo|do|other (label only)
  os              String?
  osVersion       String?   @map("os_version")
  webServer       String    @default("nginx") @map("web_server")
  baseProvisioned Boolean   @default(false) @map("base_provisioned")
  status          String    @default("pending") // pending|connected|provisioning_base|ready|unreachable|error
  lastCheckedAt   DateTime? @map("last_checked_at") @db.Timestamptz()
  facts           Json      @default("{}")
  hostKey         String?   @map("host_key") // pinned SSH host key (base64) — fail on mismatch
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  credential   Credential    @relation(fields: [credentialId], references: [id])
  deployEvents DeployEvent[]
  sites        Site[]

  @@index([tenantId])
  @@map("servers")
}

model Client {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String // business/brand name
  contactName String?  @map("contact_name")
  email       String?
  phone       String?
  company     String?
  gstin       String?
  address     String?
  city        String?
  state       String?
  country     String   @default("US")
  websiteUrl  String?  @map("website_url")
  notes       String?
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id])
  sites  Site[]

  @@index([tenantId])
  @@map("clients")
}

model Template {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String?  @map("tenant_id") @db.Uuid // null = global/stock template
  name            String
  category        String // ecom_showcase|offer_awareness|comparison|lead_page|prelander
  description     String?
  repoPath        String   @map("repo_path") // storage path of Astro template package
  version         Int      @default(1)
  changelog       String?
  paramSchema     Json     @map("param_schema") // JSON Schema of all fill-in parameters
  previewImageUrl String?  @map("preview_image_url")
  thumbnailUrl    String?  @map("thumbnail_url")
  status          String   @default("active") // active|deprecated
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  sites  Site[]

  @@index([tenantId])
  @@map("templates")
}

model Site {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String // internal label
  clientId        String    @map("client_id") @db.Uuid
  serverId        String    @map("server_id") @db.Uuid
  templateId      String    @map("template_id") @db.Uuid
  templateVersion Int?      @map("template_version")
  // domain
  domain          String    @unique
  extraDomains    String[]  @default([]) @map("extra_domains")
  // additional outbound store hosts allowed by the compliance gate (§8) —
  // lets one page compare offers across several declared stores
  extraAllowedHosts String[] @default([]) @map("extra_allowed_hosts")
  // server-side paths (set during install, M3)
  siteSystemUser  String?   @map("site_system_user")
  documentRoot    String?   @map("document_root")
  // template parameters (filled by operator in wizard)
  params          Json      @default("{}")
  // destination (the real store visitors are sent to)
  destinationUrl  String    @map("destination_url")
  // tracking config
  ga4Id           String?   @map("ga4_id")
  metaPixelId     String?   @map("meta_pixel_id")
  googleAdsTag    Json?     @map("google_ads_tag") // {conversion_id, conversion_label, remarketing_id}
  bingUetTag      String?   @map("bing_uet_tag")
  pushvaultPropertyKey String? @map("pushvault_property_key")
  callforgeNumber String?   @map("callforge_number")
  // install state machine (driven in M3)
  installStatus   String    @default("draft") @map("install_status")
  leadWebhookUrl  String?   @map("lead_webhook_url")
  // SSL
  sslStatus       String    @default("none") @map("ssl_status")
  sslExpiresAt    DateTime? @map("ssl_expires_at") @db.Timestamptz()
  sslAutoRenew    Boolean   @default(true) @map("ssl_auto_renew")
  // site health
  lastVerifiedAt  DateTime? @map("last_verified_at") @db.Timestamptz()
  lighthouseScore Int?      @map("lighthouse_score")
  lastUptimeCheck DateTime? @map("last_uptime_check") @db.Timestamptz()
  uptimeStatus    String?   @map("uptime_status")
  // lifecycle
  status          String    @default("draft") // draft|building|published|paused|archived
  publishedAt     DateTime? @map("published_at") @db.Timestamptz()
  lastBuildId     String?   @map("last_build_id") @db.Uuid
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  client   Client   @relation(fields: [clientId], references: [id])
  server   Server   @relation(fields: [serverId], references: [id])
  template      Template       @relation(fields: [templateId], references: [id])
  builds        Build[]
  campaignLinks CampaignLink[]
  leads         Lead[]

  @@index([tenantId])
  @@map("sites")
}

model Build {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  siteId          String   @map("site_id") @db.Uuid
  status          String   @default("queued") // queued|building|success|failed
  log             String?
  artifactPath    String?  @map("artifact_path") // storage key of zipped dist/
  durationMs      Int?     @map("duration_ms")
  lighthouseScore Int?     @map("lighthouse_score")
  createdBy       String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id])
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([tenantId, siteId, createdAt])
  @@map("builds")
}

model CampaignLink {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  siteId             String   @map("site_id") @db.Uuid
  platform           String // google|meta|bing
  campaignName       String   @map("campaign_name")
  utm                Json // {source,medium,campaign,content,term}
  finalUrl           String   @map("final_url") // ready to paste into the ad
  externalCampaignId String?  @map("external_campaign_id") // set by ad-API sync (Phase 2)
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id])
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([tenantId, siteId])
  @@map("campaign_links")
}

// visits is a Postgres table PARTITIONED BY RANGE (ts) — the partitioning
// DDL lives in the hand-written m4_visits_rls migration (Prisma cannot emit
// it). The model below matches the parent table so queries/inserts work and
// the migration differ stays clean. New partitions are created monthly by
// ensure_visits_partition(), called at API boot.
model Visit {
  id          String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  siteId      String   @map("site_id") @db.Uuid
  ts          DateTime @default(now()) @db.Timestamptz()
  sessionId   String?  @map("session_id")
  utmSource   String?  @map("utm_source")
  utmMedium   String?  @map("utm_medium")
  utmCampaign String?  @map("utm_campaign")
  utmContent  String?  @map("utm_content")
  utmTerm     String?  @map("utm_term")
  referrer    String?
  path        String?
  country     String?  @db.Char(2)
  device      String?
  browser     String?
  event       String // pageview|cta_click|outbound_click|push_prompt_shown|push_subscribed|lead_submit
  meta        Json?

  @@id([id, ts])
  @@index([siteId, utmCampaign, ts], map: "visits_site_campaign_ts")
  @@index([tenantId, siteId, ts], map: "visits_tenant_site_ts")
  @@map("visits")
}

// Cached external product-search results (SerpApi). Public shopping data,
// not tenant data — no tenant_id; only the owner/admin DB identity touches
// it (REVOKEd from the app role). Cache hits cost zero API credits.
model SearchCache {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  engine    String // e.g. google_shopping
  query     String
  gl        String   @default("us") // market
  results   Json
  fetchedAt DateTime @default(now()) @map("fetched_at") @db.Timestamptz()

  @@index([engine, query, gl, fetchedAt])
  @@map("search_cache")
}

model Lead {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  siteId    String   @map("site_id") @db.Uuid
  fields    Json // {name, email, phone, ...} exactly as submitted
  consent   Boolean // §13: must be true to store — enforced in code AND DB
  sourceUtm Json?    @map("source_utm")
  ipHash    String?  @map("ip_hash") // salted SHA-256; raw IP never stored
  at        DateTime @default(now()) @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id])
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([tenantId, siteId, at])
  @@map("leads")
}

model DeployEvent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  siteId         String?  @map("site_id") @db.Uuid // FK added when sites table lands (M2/M3)
  serverId       String   @map("server_id") @db.Uuid
  step           String
  status         String // start|ok|fail
  commandSummary String?  @map("command_summary") // SANITIZED — never contains secrets
  outputTail     String?  @map("output_tail") // last 500 chars of ssh output
  at             DateTime @default(now()) @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id])
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([tenantId, serverId, at])
  @@map("deploy_events")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  before     Json?
  after      Json?
  ip         String?
  at         DateTime @default(now()) @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, at])
  @@map("audit_log")
}
